{
  "extends": "../../tsconfig.json",
  "include": ["src/**/*.ts"],
  "ts-node": {
    // It is faster to skip typechecking.
    // Remove if you want ts-node to do typechecking.
    "transpileOnly": true,
    "files": true
  },
  "compilerOptions": {
    "outDir": "./dist",
    "noEmit": false,
    "sourceMap": true,
    "declaration": true,
    "esModuleInterop": true,
    "module": "nodenext",
    "target": "esnext",
    "lib": ["esnext"],
    "types": ["node"],
    "rootDir": "./src"
  },
  "references": [
    {
      "path": "../../common/types"
    }
  ],
  "exclude": ["src/test-helpers", "dist", "test", "**/*test.ts"]
}
